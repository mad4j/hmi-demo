# hmi-demo environment templates
#
# Copy this file to .env.local (recommended) and keep only one profile active.
# Vite loads VITE_* variables at build/runtime.

# -----------------------------------------------------------------------------
# PROFILE A - Default network path + Service Worker simulator
# -----------------------------------------------------------------------------
VITE_DEVICE_ADAPTER_MODE=network-auto
VITE_DEVICE_API_BASE_URL=
VITE_ENABLE_SW_SIMULATOR=true

# -----------------------------------------------------------------------------
# PROFILE B - Direct simulator in main thread (no SW interception)
# -----------------------------------------------------------------------------
# VITE_DEVICE_ADAPTER_MODE=simulator-direct
# VITE_DEVICE_API_BASE_URL=
# VITE_ENABLE_SW_SIMULATOR=false

# -----------------------------------------------------------------------------
# PROFILE C - Real backend (same DeviceAdapter API /api/*)
# -----------------------------------------------------------------------------
# VITE_DEVICE_ADAPTER_MODE=network-auto
# VITE_DEVICE_API_BASE_URL=http://192.168.1.100:8080
# VITE_ENABLE_SW_SIMULATOR=false
